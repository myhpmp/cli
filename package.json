{
  "name": "@myhpmp/cli",
  "version": "1.8.1",
  "description": "RPG-style gamified usage dashboard for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "myhpmp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:publish": "tsc && node scripts/inject-config.js",
    "prepublishOnly": "npm run build:publish",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude",
    "claude-code",
    "gamification",
    "rpg",
    "usage",
    "dashboard",
    "status-line",
    "level",
    "exp"
  ],
  "author": "imironjin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myhpmp/cli.git"
  },
  "homepage": "https://github.com/myhpmp/cli",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@myhpmp/core": "^1.1.1",
    "@supabase/supabase-js": "^2.49.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
